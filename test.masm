# round-trip test: exercises data movement, arithmetic, control flow,
# memory ops, comparisons, conversions, and multiple functions.

data msg : rodata global align=1 bytes 12

fun main {
  .entry:
    mov.8 r0, 0
    mov.8 r1, 10
    jmp .loop
  .loop:
    icmp.lt.8 r2, r0, r1
    brcond r2, .body
    jmp .exit
  .body:
    add.8 r0, r0, 1
    jmp .loop
  .exit:
    ret
}

fun arith {
  .entry:
    param p0, 8, td0
    param p1, 8, td0
    add.8 r2, r0, r1
    sub.8 r3, r0, r1
    mul.8 r4, r0, r1
    div.8 r5, r2, r3
    and.8 r6, r0, r1
    or.8 r7, r0, r1
    xor.8 r8, r0, r1
    shl.8 r9, r0, r1
    shr.8 r10, r0, r1
    ret.8 r2, td0
}

fun memory {
  .entry:
    mov.8 r0, 100
    store.8 r0, [sp + 0]
    load.8 r1, [sp + 0]
    store.4 r0, [sp + 8]
    load.4 r2, [sp + 8]
    ret
}

fun conversions {
  .entry:
    param p0, 4, td0
    mov.4 r0, 42
    zext.8 r1, r0
    sext.8 r2, r0
    trunc.2 r3, r0
    trunc.1 r4, r0
    ret
}
