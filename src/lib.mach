# masm: target-independent intermediate assembly format
#
# provides the core types for MASM: instructions, per-function pools,
# symbols, data declarations, and the immutable Module container.
# consumed by compiler backends, linkers, and analysis tools.

use masm.inst;
use masm.pool;
use masm.symbol;
use masm.function;
use masm.data;
use masm.module;
