# masm: target-independent intermediate assembly format
#
# provides the core types for MASM: opcodes, instructions, per-function
# pools, type descriptors, symbols, data declarations, and the immutable
# Module container. consumed by compiler backends, linkers, and analysis
# tools.

use masm.op;
use masm.inst;
use masm.pool;
use masm.typedesc;
use masm.symbol;
use masm.function;
use masm.data;
use masm.module;
use masm.strtab;
use masm.symtab;
